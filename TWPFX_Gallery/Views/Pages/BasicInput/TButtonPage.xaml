<Page
    x:Class="TWPFX_Gallery.Views.Pages.BasicInput.TButtonPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:example="clr-namespace:TWPFX.Controls.Example;assembly=TWPFX"
    xmlns:local="clr-namespace:TWPFX_Gallery.Views.Pages.BasicInput"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:segoeicon="clr-namespace:TWPFX.Controls.Icon.SegoeIcon;assembly=TWPFX"
    xmlns:tbutton="clr-namespace:TWPFX.Controls.Button.TButton;assembly=TWPFX"
    xmlns:viewmodels="clr-namespace:TWPFX_Gallery.ViewModels.Pages.BasicInput"
    Title="TButton"
    d:DataContext="{d:DesignInstance local:TButtonPage,
                                     IsDesignTimeCreatable=False}"
    mc:Ignorable="d">

    <StackPanel>
        <example:TControlExampleExpander
            Margin="0,24,0,0"
            Code="{Binding ViewModel.TBaseButtonCode}"
            Header="TBaseButton"
            Lang="XAML">
            <tbutton:TBaseButton
                Width="81"
                Height="31"
                BackgroundColor="#21222d"
                BorderBrush="#eaeaea"
                Command="{Binding ViewModel.ButtonClickCommand, Mode=OneWay}"
                FontSize="14"
                FontWeight="Bold"
                HoverBackgroundColor="#373842"
                HoverBorderColor="#eaeaea"
                HoverIconColor="#eaeaeb"
                HoverTextColor="#eaeaeb"
                Icon="Settings"
                IconColor="#ffffff"
                PressedBackgroundColor="#73747b"
                PressedBorderColor="#eaeaea"
                PressedIconColor="#eaeaeb"
                PressedTextColor="#eaeaeb"
                Text="设置"
                TextColor="#ffffff" />
        </example:TControlExampleExpander>

        <example:TControlExampleExpander
            Margin="0,24,0,0"
            Code="{Binding ViewModel.TButtonCode}"
            Header="TButton"
            Lang="XAML">
            <StackPanel>
                <TextBlock FontWeight="Bold" Text="Solid" />
                <StackPanel Margin="0,12,0,0" Orientation="Horizontal">
                    <tbutton:TButton
                        Width="101"
                        Height="31"
                        Appearance="Default"
                        ButtonStyle="Solid"
                        Command="{Binding ViewModel.ButtonClickCommand, Mode=OneWay}"
                        FontSize="14"
                        FontWeight="Bold"
                        Icon="ReportDocument"
                        Text="Default" />
                    <tbutton:TButton
                        Width="101"
                        Height="31"
                        Margin="24,0,0,0"
                        Appearance="System"
                        ButtonStyle="Solid"
                        Command="{Binding ViewModel.ButtonClickCommand, Mode=OneWay}"
                        FontSize="14"
                        FontWeight="Bold"
                        Icon="ReportDocument"
                        Text="System" />
                    <tbutton:TButton
                        Width="101"
                        Height="31"
                        Margin="24,0,0,0"
                        Appearance="Primary"
                        ButtonStyle="Solid"
                        Command="{Binding ViewModel.ButtonClickCommand, Mode=OneWay}"
                        FontSize="14"
                        FontWeight="Bold"
                        Icon="ReportDocument"
                        Text="Primary" />
                    <tbutton:TButton
                        Width="101"
                        Height="31"
                        Margin="24,0,0,0"
                        Appearance="Info"
                        ButtonStyle="Solid"
                        Command="{Binding ViewModel.ButtonClickCommand, Mode=OneWay}"
                        FontSize="14"
                        Icon="ReportDocument"
                        Text="Info" />
                    <tbutton:TButton
                        Width="101"
                        Height="31"
                        Margin="24,0,0,0"
                        Appearance="Success"
                        ButtonStyle="Solid"
                        Command="{Binding ViewModel.ButtonClickCommand, Mode=OneWay}"
                        FontSize="14"
                        FontWeight="Bold"
                        Icon="ReportDocument"
                        Text="Success" />
                    <tbutton:TButton
                        Width="101"
                        Height="31"
                        Margin="24,0,0,0"
                        Appearance="Warning"
                        ButtonStyle="Solid"
                        Command="{Binding ViewModel.ButtonClickCommand, Mode=OneWay}"
                        FontSize="14"
                        FontWeight="Bold"
                        Icon="ReportDocument"
                        Text="Warning" />
                    <tbutton:TButton
                        Width="101"
                        Height="31"
                        Margin="24,0,0,0"
                        Appearance="Danger"
                        ButtonStyle="Solid"
                        Command="{Binding ViewModel.ButtonClickCommand, Mode=OneWay}"
                        FontSize="14"
                        FontWeight="Bold"
                        Icon="ReportDocument"
                        Text="Danger" />
                </StackPanel>
                <TextBlock
                    Margin="0,36,0,0"
                    FontWeight="Bold"
                    Text="Outlined" />
                <StackPanel Margin="0,12,0,0" Orientation="Horizontal">
                    <tbutton:TButton
                        Width="101"
                        Height="31"
                        Appearance="Default"
                        ButtonStyle="Outlined"
                        FontSize="14"
                        FontWeight="Bold"
                        Icon="ReportDocument"
                        Text="Default" />
                    <tbutton:TButton
                        Width="101"
                        Height="31"
                        Margin="24,0,0,0"
                        Appearance="System"
                        ButtonStyle="Outlined"
                        Command="{Binding ViewModel.ButtonClickCommand, Mode=OneWay}"
                        FontSize="14"
                        FontWeight="Bold"
                        Icon="ReportDocument"
                        Text="System" />
                    <tbutton:TButton
                        Width="101"
                        Height="31"
                        Margin="24,0,0,0"
                        Appearance="Primary"
                        ButtonStyle="Outlined"
                        Command="{Binding ViewModel.ButtonClickCommand, Mode=OneWay}"
                        FontSize="14"
                        FontWeight="Bold"
                        Icon="ReportDocument"
                        Text="Primary" />
                    <tbutton:TButton
                        Width="101"
                        Height="31"
                        Margin="24,0,0,0"
                        Appearance="Info"
                        ButtonStyle="Outlined"
                        Command="{Binding ViewModel.ButtonClickCommand, Mode=OneWay}"
                        FontSize="14"
                        FontWeight="Bold"
                        Icon="ReportDocument"
                        Text="Info" />
                    <tbutton:TButton
                        Width="101"
                        Height="31"
                        Margin="24,0,0,0"
                        Appearance="Success"
                        ButtonStyle="Outlined"
                        Command="{Binding ViewModel.ButtonClickCommand, Mode=OneWay}"
                        FontSize="14"
                        FontWeight="Bold"
                        Icon="ReportDocument"
                        Text="Success" />
                    <tbutton:TButton
                        Width="101"
                        Height="31"
                        Margin="24,0,0,0"
                        Appearance="Warning"
                        ButtonStyle="Outlined"
                        Command="{Binding ViewModel.ButtonClickCommand, Mode=OneWay}"
                        FontSize="14"
                        FontWeight="Bold"
                        Icon="ReportDocument"
                        Text="Warning" />
                    <tbutton:TButton
                        Width="101"
                        Height="31"
                        Margin="24,0,0,0"
                        Appearance="Danger"
                        ButtonStyle="Outlined"
                        Command="{Binding ViewModel.ButtonClickCommand, Mode=OneWay}"
                        FontSize="14"
                        FontWeight="Bold"
                        Icon="ReportDocument"
                        Text="Danger" />
                </StackPanel>
                <TextBlock
                    Margin="0,36,0,0"
                    FontWeight="Bold"
                    Text="Filled" />
                <StackPanel Margin="0,12,0,0" Orientation="Horizontal">
                    <tbutton:TButton
                        Width="101"
                        Height="31"
                        Appearance="Default"
                        ButtonStyle="Filled"
                        Command="{Binding ViewModel.ButtonClickCommand, Mode=OneWay}"
                        FontSize="14"
                        FontWeight="Bold"
                        Icon="ReportDocument"
                        Text="Default" />
                    <tbutton:TButton
                        Width="101"
                        Height="31"
                        Margin="24,0,0,0"
                        Appearance="System"
                        ButtonStyle="Filled"
                        Command="{Binding ViewModel.ButtonClickCommand, Mode=OneWay}"
                        FontSize="14"
                        FontWeight="Bold"
                        Icon="ReportDocument"
                        Text="System" />
                    <tbutton:TButton
                        Width="101"
                        Height="31"
                        Margin="24,0,0,0"
                        Appearance="Primary"
                        ButtonStyle="Filled"
                        Command="{Binding ViewModel.ButtonClickCommand, Mode=OneWay}"
                        FontSize="14"
                        FontWeight="Bold"
                        Icon="ReportDocument"
                        Text="Primary" />
                    <tbutton:TButton
                        Width="101"
                        Height="31"
                        Margin="24,0,0,0"
                        Appearance="Info"
                        ButtonStyle="Filled"
                        Command="{Binding ViewModel.ButtonClickCommand, Mode=OneWay}"
                        FontSize="14"
                        FontWeight="Bold"
                        Icon="ReportDocument"
                        Text="Info" />
                    <tbutton:TButton
                        Width="101"
                        Height="31"
                        Margin="24,0,0,0"
                        Appearance="Success"
                        ButtonStyle="Filled"
                        Command="{Binding ViewModel.ButtonClickCommand, Mode=OneWay}"
                        FontSize="14"
                        FontWeight="Bold"
                        Icon="ReportDocument"
                        Text="Success" />
                    <tbutton:TButton
                        Width="101"
                        Height="31"
                        Margin="24,0,0,0"
                        Appearance="Warning"
                        ButtonStyle="Filled"
                        Command="{Binding ViewModel.ButtonClickCommand, Mode=OneWay}"
                        FontSize="14"
                        FontWeight="Bold"
                        Icon="ReportDocument"
                        Text="Warning" />
                    <tbutton:TButton
                        Width="101"
                        Height="31"
                        Margin="24,0,0,0"
                        Appearance="Danger"
                        ButtonStyle="Filled"
                        Command="{Binding ViewModel.ButtonClickCommand, Mode=OneWay}"
                        FontSize="14"
                        FontWeight="Bold"
                        Icon="ReportDocument"
                        Text="Danger" />
                </StackPanel>
                <TextBlock
                    Margin="0,36,0,0"
                    FontWeight="Bold"
                    Text="Circle" />
                <StackPanel Margin="0,12,0,0" Orientation="Horizontal">
                    <tbutton:TButton
                        Width="31"
                        Height="31"
                        Appearance="Default"
                        ButtonStyle="Circle"
                        Command="{Binding ViewModel.ButtonClickCommand, Mode=OneWay}"
                        FontSize="14"
                        FontWeight="Bold"
                        Icon="Add" />
                    <tbutton:TButton
                        Width="31"
                        Height="31"
                        Margin="24,0,0,0"
                        Appearance="System"
                        ButtonStyle="Circle"
                        Command="{Binding ViewModel.ButtonClickCommand, Mode=OneWay}"
                        FontSize="14"
                        FontWeight="Bold"
                        Icon="Add" />
                    <tbutton:TButton
                        Width="31"
                        Height="31"
                        Margin="24,0,0,0"
                        Appearance="Primary"
                        ButtonStyle="Circle"
                        Command="{Binding ViewModel.ButtonClickCommand, Mode=OneWay}"
                        FontSize="14"
                        FontWeight="Bold"
                        Icon="Add" />
                    <tbutton:TButton
                        Width="31"
                        Height="31"
                        Margin="24,0,0,0"
                        Appearance="Info"
                        ButtonStyle="Circle"
                        Command="{Binding ViewModel.ButtonClickCommand, Mode=OneWay}"
                        FontSize="14"
                        FontWeight="Bold"
                        Icon="Add" />
                    <tbutton:TButton
                        Width="31"
                        Height="31"
                        Margin="24,0,0,0"
                        Appearance="Success"
                        ButtonStyle="Circle"
                        Command="{Binding ViewModel.ButtonClickCommand, Mode=OneWay}"
                        FontSize="14"
                        FontWeight="Bold"
                        Icon="Add" />
                    <tbutton:TButton
                        Width="31"
                        Height="31"
                        Margin="24,0,0,0"
                        Appearance="Warning"
                        ButtonStyle="Circle"
                        Command="{Binding ViewModel.ButtonClickCommand, Mode=OneWay}"
                        FontSize="14"
                        FontWeight="Bold"
                        Icon="Add" />
                    <tbutton:TButton
                        Width="31"
                        Height="31"
                        Margin="24,0,0,0"
                        Appearance="Danger"
                        ButtonStyle="Circle"
                        Command="{Binding ViewModel.ButtonClickCommand, Mode=OneWay}"
                        FontSize="14"
                        FontWeight="Bold"
                        Icon="Add" />
                </StackPanel>
            </StackPanel>
        </example:TControlExampleExpander>

        <example:TControlExampleExpander
            Margin="0,24,0,0"
            Code="{Binding ViewModel.TBaseButtonCode}"
            Header="TLoadingButton"
            Lang="XAML">
            <StackPanel>
                <TextBlock FontWeight="Bold" Text="不同外观类型" />
                <StackPanel Margin="0,12,0,0" Orientation="Horizontal">
                    <tbutton:TLoadingButton
                        Width="120"
                        Height="40"
                        Appearance="Default"
                        IsLoading="True"
                        Text="Default" />
                    <tbutton:TLoadingButton
                        Width="120"
                        Height="31"
                        Margin="24,0,0,0"
                        Appearance="Primary"
                        IsLoading="True"
                        Text="Primary" />
                    <tbutton:TLoadingButton
                        Width="120"
                        Height="31"
                        Margin="24,0,0,0"
                        Appearance="System"
                        IsLoading="True"
                        Text="System" />
                    <tbutton:TLoadingButton
                        Width="120"
                        Height="31"
                        Margin="24,0,0,0"
                        Appearance="Info"
                        IsLoading="True"
                        Text="Info" />
                    <tbutton:TLoadingButton
                        Width="120"
                        Height="31"
                        Margin="24,0,0,0"
                        Appearance="Success"
                        IsLoading="True"
                        Text="Success" />
                    <tbutton:TLoadingButton
                        Width="120"
                        Height="31"
                        Margin="24,0,0,0"
                        Appearance="Warning"
                        IsLoading="True"
                        Text="Warning" />
                    <tbutton:TLoadingButton
                        Width="120"
                        Height="31"
                        Margin="24,0,0,0"
                        Appearance="Danger"
                        IsLoading="True"
                        Text="Danger" />
                </StackPanel>

                <TextBlock
                    Margin="0,36,0,0"
                    FontWeight="Bold"
                    Text="不同尺寸和样式" />
                <StackPanel Margin="0,12,0,0" Orientation="Horizontal">
                    <tbutton:TLoadingButton
                        Width="91"
                        Height="24"
                        Appearance="Primary"
                        IsLoading="True"
                        LoadingRingStrokeThickness="2"
                        Text="小尺寸" />
                    <tbutton:TLoadingButton
                        Width="120"
                        Height="31"
                        Margin="24,0,0,0"
                        Appearance="Success"
                        IsLoading="True"
                        LoadingRingStrokeThickness="2.0"
                        Text="标准尺寸" />
                    <tbutton:TLoadingButton
                        Width="160"
                        Height="40"
                        Margin="24,0,0,0"
                        Appearance="Warning"
                        IsLoading="True"
                        LoadingRingStrokeThickness="3.0"
                        Text="大尺寸" />
                </StackPanel>
            </StackPanel>

        </example:TControlExampleExpander>
    </StackPanel>
</Page> 